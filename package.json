{
  "name": "opentrust-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "npm run dev --workspace=packages/core & npm run dev --workspace=packages/demo",
    "test": "npm run test --workspace=packages/core",
    "test:all": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces"
  },
  "devDependencies": {
    "happy-dom": "^20.11.1",
    "typescript": "^5.4.0",
    "vitest": "^4.1.10"
  }
}

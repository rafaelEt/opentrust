{
  "name": "opentrust-sdk",
  "version": "0.1.3",
  "description": "OpenTrust SDK — Privacy-first human presence verification. Detect bots, deepfakes, and automated browsers.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rafaelEt/opentrust.git"
  },
  "homepage": "https://github.com/rafaelEt/opentrust#readme",
  "bugs": {
    "url": "https://github.com/rafaelEt/opentrust/issues"
  },
  "keywords": [
    "open-trust",
    "liveness",
    "deepfake-detection",
    "bot-detection",
    "privacy-first",
    "browser-automation",
    "anti-fraud",
    "captcha"
  ],
  "license": "MIT"
}
